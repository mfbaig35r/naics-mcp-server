{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.mfbaig35r/naics-mcp-server",
  "title": "NAICS 2022 Classification",
  "description": "Self-contained NAICS 2022 industry classification with semantic search, hierarchy browsing, and cross-references",
  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/mfbaig35r/naics-mcp-server"
  },
  "packages": [
    {
      "registryType": "oci",
      "identifier": "docker.io/mfbaig35r/naics-mcp-server:latest",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "NAICS_LOG_LEVEL",
          "description": "Logging level (DEBUG, INFO, WARNING, ERROR)",
          "isRequired": false,
          "isSecret": false,
          "default": "INFO"
        },
        {
          "name": "NAICS_EMBEDDING_MODEL",
          "description": "Sentence-transformers model for semantic search",
          "isRequired": false,
          "isSecret": false,
          "default": "all-MiniLM-L6-v2"
        }
      ]
    }
  ]
}
